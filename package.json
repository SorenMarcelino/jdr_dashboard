{
  "name": "jdr_dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node back/server.mjs",
    "dev:test": "NODE_ENV=test node back/server.mjs",
    "front": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "gen-secrets": "node -e \"const c=require('crypto');for(const k of ['TOKEN_KEY','REFRESH_TOKEN_KEY'])console.log(k+'='+c.randomBytes(48).toString('hex'))\"",
    "test": "node back/tests/run-all-tests.mjs",
    "test:unit": "node --test back/tests/unit/",
    "test:create-user": "node back/tests/test-create-user.mjs",
    "test:refresh": "node -r dotenv/config back/tests/test-refresh.mjs dotenv_config_path=.env.test"
  },
  "dependencies": {
    "@3d-dice/dice-box-threejs": "^0.0.12",
    "@headlessui/react": "^2.2.0",
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^4.0.0",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-collapsible": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tiptap/extension-placeholder": "^3.20.5",
    "@tiptap/pm": "^3.20.5",
    "@tiptap/react": "^3.20.5",
    "@tiptap/starter-kit": "^3.20.5",
    "@xyflow/react": "^12.10.1",
    "axios": "^1.13.4",
    "axios-cookiejar-support": "^6.0.5",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.1.0",
    "framer-motion": "^12.0.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.473.0",
    "mongoose": "^8.9.7",
    "morgan": "^1.10.0",
    "next": "^15.5.19",
    "next-themes": "^0.4.4",
    "nodemon": "^3.1.9",
    "pino": "^10.3.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-grid-layout": "^2.2.2",
    "react-hook-form": "^7.54.2",
    "react-resizable-panels": "^4.7.5",
    "react-toastify": "^11.0.3",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "tough-cookie": "^6.0.0",
    "validator": "^13.15.15",
    "zod": "^3.24.1"
  },
  "overrides": {
    "ws": "^8.21.0",
