    "@types/react-dom": "^19",
    "@types/react-grid-layout": "^2.1.0",
    "eslint": "^9",
    "eslint-config-next": "^15.5.19",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
