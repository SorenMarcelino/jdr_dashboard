# Copier vers .env sur le VPS, renseigner les vraies valeurs, puis lancer :
#   docker compose -f docker-compose.prod.yml up -d --build
# Ne jamais committer .env.

# --- Hôte public du déploiement --------------------------------------------
# Sans nom de domaine, utiliser nip.io : remplacer les points de l'IP par des
# tirets, ex. IP 203.0.113.42 -> 203-0-113-42.nip.io. Caddy obtiendra un
# certificat Let's Encrypt automatiquement au premier démarrage.
SITE_HOSTNAME=VOTRE-IP-EN-TIRETS.nip.io

# --- MongoDB Atlas ----------------------------------------------------------
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/jdr_dashboard?retryWrites=true&w=majority

# --- Auth (REQUIS) ----------------------------------------------------------
# Générer avec : npm run gen-secrets
TOKEN_KEY=
REFRESH_TOKEN_KEY=

# Durées de vie des tokens (secondes) — optionnel, valeurs par défaut sinon.
# ACCESS_TOKEN_EXPIRY=1800
# REFRESH_TOKEN_EXPIRY=1209600

# NODE_ENV, PORT et CORS_ORIGIN sont fixés par docker-compose.prod.yml.
